# =========================================================================
# ATTENDIFY — ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to '.env' in the project root and populate it with your
# live credentials to connect Attendify to your Firebase project and SMTP host.
# =========================================================================

# -------------------------------------------------------------------------
# 1. FIREBASE AUTH & FIRESTORE DATABASE CONFIGURATION (Client & Server)
# -------------------------------------------------------------------------
# Obtain these values from your Firebase Project settings Console:
# Project Overview -> Gear Icon -> Project settings -> Your apps (Web App)
# -------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id_here

# -------------------------------------------------------------------------
# 2. SMTP AUTOMATED EMAIL SERVICE CONFIGURATION (Server-side Nodemailer)
# -------------------------------------------------------------------------
# Configure these to deliver professional branded HTML credential cards
# and recovery codes directly to students' and lecturers' email inboxes:
# -------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_university_noreply_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
